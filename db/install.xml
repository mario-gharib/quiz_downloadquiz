<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/quiz/report/downloadquiz/db" VERSION="2026041500" COMMENT="XMLDB file for quiz_downloadquiz"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">

    <TABLES>
        <TABLE NAME="quiz_downloadquiz_grants" COMMENT="Stores temporary access grants for quiz download">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="User granted access"/>
                <FIELD NAME="grantedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="User who granted access"/>
                <FIELD NAME="timegranted" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Grant creation timestamp"/>
                <FIELD NAME="timeexpires" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Expiry timestamp"/>
                <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1" COMMENT="Whether the grant is currently active"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
            </FIELDS>

            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="userid_fk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
                <KEY NAME="grantedby_fk" TYPE="foreign" FIELDS="grantedby" REFTABLE="user" REFFIELDS="id"/>
            </KEYS>

            <INDEXES>
                <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
                <INDEX NAME="timeexpires_idx" UNIQUE="false" FIELDS="timeexpires"/>
                <INDEX NAME="enabled_idx" UNIQUE="false" FIELDS="enabled"/>
            </INDEXES>
        </TABLE>
    </TABLES>
</XMLDB>